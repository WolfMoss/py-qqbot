# ────────────────────────────────────────────────────
# QQ Bot 配置模板
# 复制此文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会被提交到仓库
# ────────────────────────────────────────────────────

# QQ 开放平台 -> 机器人管理 -> 开发设置 中获取
QQ_APP_ID=your_app_id_here
QQ_APP_SECRET=your_app_secret_here

# 沙盒模式：true=测试环境 / false=正式环境
QQ_SANDBOX=true

# 回复消息前缀（可留空）
REPLY_PREFIX=

# 日志等级：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
